[Unit]
Description=Ship's Core Communications Console
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/ship_mind_communication
Environment=PYTHONPATH=/home/pi/ship_mind_communication/src
Environment=SHIP_MESHTASTIC_MODE=mock
ExecStart=/home/pi/ship_mind_communication/.venv/bin/python -m uvicorn ships_mind.app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
